            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"Derived RecoveryScore\")\n  |> filter(fn: (r) => r._field == \"score\")\n  |> filter(fn: (r) => r.MetricClass == \"Derived\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"score\")",
          "refId": "A"
        }
      ],
      "title": "[Derived] Recovery Score",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
