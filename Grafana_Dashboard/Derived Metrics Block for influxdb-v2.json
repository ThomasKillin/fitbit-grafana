          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"Derived RecoveryScore\")\n  |> filter(fn: (r) => r._field == \"score\" or r._field == \"confidence\")\n  |> filter(fn: (r) => r.MetricClass == \"Derived\")\n  |> aggregateWindow(every: 1d, fn: mean, createEmpty: false)\n  |> pivot(rowKey:[\"_time\"], columnKey:[\"_field\"], valueColumn:\"_value\")\n  |> filter(fn: (r) => r.confidence >= 0.75)\n  |> map(fn: (r) => ({_time: r._time, _field: \"score\", _value: r.score}))\n  |> yield(name: \"score\")",
          "refId": "A"
        }
      ],
      "title": "[Derived] Recovery Score",
      "type": "timeseries"
